# Copy to `.env` and adjust. Only VITE_-prefixed vars are exposed to the client.
# All values here are validated at boot by src/config/env.ts (Zod) — the app
# fails fast with a clear error if a required var is missing or malformed.

# Base URL for the API. Requests in src/lib/api are prefixed with this.
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Human-readable app name (used in titles, sidebar, etc.)
VITE_APP_NAME=React Boilerplate

# Dev-only: vite proxy target for /api (see vite.config.ts)
VITE_API_PROXY_TARGET=http://localhost:8080

# --- Optional, feature-flagged integrations (off by default) ---

# Error monitoring (Sentry). Set to true and provide a DSN to enable.
VITE_ENABLE_SENTRY=false
VITE_SENTRY_DSN=

# Install a PWA service worker (see docs/ARCHITECTURE.md → opt-in add-ons).
VITE_ENABLE_PWA=false
