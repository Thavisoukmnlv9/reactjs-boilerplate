{
  "name": "reactjs-boilerplate",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Production-grade, modular, feature-based React + TypeScript boilerplate.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "gen:feature": "plop feature",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@radix-ui/primitive": "^1.1.4",
    "@radix-ui/react-accordion": "^1.2.15",
    "@radix-ui/react-alert-dialog": "^1.1.18",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.1",
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-collapsible": "^1.1.15",
    "@radix-ui/react-compose-refs": "^1.1.3",
    "@radix-ui/react-context-menu": "^2.3.2",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-hover-card": "^1.1.18",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-menubar": "^1.1.19",
    "@radix-ui/react-navigation-menu": "^1.2.17",
    "@radix-ui/react-popover": "^1.1.18",
    "@radix-ui/react-primitive": "^2.1.7",
    "@radix-ui/react-progress": "^1.1.11",
    "@radix-ui/react-radio-group": "^1.4.2",
    "@radix-ui/react-scroll-area": "^1.2.13",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slider": "^1.4.2",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-tabs": "^1.1.16",
    "@radix-ui/react-toast": "^1.2.18",
    "@radix-ui/react-toggle": "^1.1.13",
    "@radix-ui/react-toggle-group": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.11",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@sentry/react": "^10.62.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "axios": "^1.18.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "embla-carousel-react": "^8.6.0",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "lodash.debounce": "^4.0.8",
    "lucide-react": "^1.22.0",
    "motion": "^12.42.2",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.6.1",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-i18next": "^17.0.8",
    "react-phone-number-input": "^3.4.17",
    "react-resizable-panels": "^4.12.0",
    "react-router-dom": "^7.18.1",
    "@tanstack/react-router": "^1.170.16",
    "recharts": "^3.9.1",
    "secure-ls": "^2.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/lodash.debounce": "^4.0.9",
    "@types/node": "^26.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "msw": "^2.14.6",
    "plop": "^4.0.5",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
